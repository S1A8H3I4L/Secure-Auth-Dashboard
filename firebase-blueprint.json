{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role in the system."
        },
        "status": {
          "type": "string",
          "enum": ["active", "banned"],
          "description": "The user's account status."
        },
        "location": {
          "type": "string",
          "description": "The user's location."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "system"],
          "description": "The user's preferred theme."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created."
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "When the user last logged in."
        }
      },
      "required": ["uid", "email", "displayName"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Stores user activity logs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "type": { "type": "string", "enum": ["login", "logout", "update", "security", "failed_login"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "type", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Stores user notifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Collection of activity logs."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of notifications."
    }
  }
}
